// ============================================================
// Spot Admin – Prisma Schema
// DB: PostgreSQL (same DB as spot-backend)
// New models: AdminAccount, Business, Settlement, BusinessInvitation
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums (copied from spot-backend)
// ============================================================

enum Provider {
  KAKAO
  NAVER
  APPLE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum DeviceType {
  MOBILE
  TABLET
  WEB
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum AdmissionMode {
  INSTANT
  APPROVAL
}

/// 업체 커스텀 신청 폼 질문 유형
enum FormFieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  MULTISELECT
}

/// 채팅방 유형: PARTY=파티 그룹채팅 · DM=유저↔유저 · BIZ_DM=유저↔업체
enum ChatRoomType {
  PARTY
  DM
  BIZ_DM
}

/// 메시지 발신 주체
enum ChatSenderType {
  USER
  BUSINESS
  SYSTEM
}

enum ChatMessageType {
  TEXT
  IMAGE
  VIDEO
}

// ============================================================
// New Enums (admin-specific)
// ============================================================

enum AdminRole {
  SUPER_ADMIN
  BUSINESS
}

enum SettlementStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  READY
  IN_PROGRESS
  DONE
  CANCELLED
  PARTIAL_CANCELLED
  ABORTED
  EXPIRED
}

enum PaymentMethod {
  CARD
  VIRTUAL_ACCOUNT
  TRANSFER
  MOBILE
  GIFT_CERTIFICATE
  FOREIGN_EASY_PAY
}

enum BusinessStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

// ============================================================
// Existing Models (spot-backend — read only from admin)
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  nickname     String
  profileImage String?
  socialId     String
  provider     Provider
  refreshToken String?

  averageRating Float @default(0.0)
  role          Role  @default(USER)

  isBlocked    Boolean   @default(false)
  blockedUntil DateTime?
  blockReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile             UserProfile?
  hostedParties       Party[]                  @relation("PartyAdmin")
  applications        Application[]
  ratingsGiven        UserRating[]             @relation("AdminRatings")
  ratingsReceived     UserRating[]             @relation("TargetRatings")
  partyRatings        PartyRating[]
  notificationTokens  NotificationToken[]
  notificationHistory NotificationHistory[]
  notificationSetting UserNotificationSetting?
  wishlists           Wishlist[]
  payments            Payment[]
  businessFormAnswers UserBusinessFormAnswer[]
  chatMemberships     ChatRoomMember[]
  chatMessages        ChatMessage[]
  inquiries           Inquiry[]
  coupons             UserCoupon[]

  // 업체 어드민(role=ADMIN) 지정 시 담당 업체
  businessId      String?
  managedBusiness Business? @relation("BusinessAdminUsers", fields: [businessId], references: [id], onDelete: SetNull)

  @@unique([socialId, provider])
  @@index([email])
  @@index([isBlocked])
  @@index([businessId])
  @@map("users")
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  gender         String?
  birthDate      DateTime?
  city           String?
  education      String?
  company        String?
  occupation     String?
  height         Int?
  weight         Int?
  bio            String?
  profileImages  String[]  @default([])
  phone          String?
  mbti           String?
  instagramId    String?
  smokingStatus  String?
  drinkingStatus String?
  maritalStatus  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

enum PartyCategoryStatus {
  FIXED
  NORMAL
}

/// 파티 카테고리 — 홈 메인 노출(FIXED)·검색 필터·파티 등록 선택지 (spot-backend 미러)
model PartyCategory {
  id        String              @id @default(cuid())
  name      String              @unique
  status    PartyCategoryStatus @default(NORMAL)
  sortOrder Int                 @default(0)
  isActive  Boolean             @default(true)
  iconUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parties Party[]

  @@map("party_categories")
}

/// 쿠폰 템플릿 — 어드민 정의. CLAIMABLE=앱 노출·유저 수령, SYSTEM=레퍼럴 자동 발급 (spot-backend 미러)
model CouponTemplate {
  id             String             @id @default(cuid())
  title          String
  description    String?
  discountAmount Int
  validDays      Int                @default(30)
  kind           CouponTemplateKind @default(CLAIMABLE)
  isActive       Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coupons UserCoupon[]

  @@map("coupon_templates")
}

enum CouponTemplateKind {
  CLAIMABLE
  SYSTEM
}

/// 유저 보유 쿠폰 (spot-backend 미러)
model UserCoupon {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   CouponTemplate @relation(fields: [templateId], references: [id])

  status    UserCouponStatus @default(ACTIVE)
  source    CouponSource     @default(CLAIM)
  issuedAt  DateTime         @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@index([userId, status])
  @@index([userId, templateId, source])
  @@map("user_coupons")
}

enum UserCouponStatus {
  ACTIVE
  USED
  EXPIRED
}

enum CouponSource {
  CLAIM
  REFERRAL
  ADMIN
}

/// 칭찬 태그 카테고리 — 이름·정렬 관리, name이 앱 섹션 제목 (spot-backend 미러)
model PraiseTagCategory {
  id        String @id @default(cuid())
  name      String @unique
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tags PraiseTag[]

  @@map("praise_tag_categories")
}

/// 파티 종료 후 피어리뷰 칭찬 태그 — 라벨·카테고리·정렬·노출 관리 (spot-backend 미러)
model PraiseTag {
  id         String            @id @default(cuid())
  categoryId String
  category   PraiseTagCategory @relation(fields: [categoryId], references: [id])
  label      String
  sortOrder  Int               @default(0)
  isActive   Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, sortOrder])
  @@map("praise_tags")
}

/// 유저/웹 1:1 문의 — spot-backend 미러 (APP: 앱, WEB: dopa-web)
model Inquiry {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  message    String
  contact    String?
  source     String   @default("APP")
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([isResolved, createdAt])
  @@index([source, createdAt])
  @@map("inquiries")
}

model Party {
  id           String   @id @default(cuid())
  title        String
  description  String
  date         DateTime
  location     String
  maxCapacity  Int
  currentCount Int      @default(0)
  isActive     Boolean  @default(true)

  requiredFields String[] @default([])

  coverImage    String?
  priceMale     Int     @default(0)
  priceFemale   Int     @default(0)
  genderRatio   String?
  /// categoryId의 이름 사본 (구버전 앱 호환)
  category      String?
  categoryId    String?
  categoryRef   PartyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  admissionMode AdmissionMode @default(APPROVAL)
  averageRating Float         @default(0.0)
  featuredUntil  DateTime?
  featuredWeight Int           @default(0)

  adminId String
  admin   User   @relation("PartyAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  // 파티를 업체에 연결 (선택적 — 어드민 앱에서 추가)
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications Application[]
  partyRatings PartyRating[]
  wishlists    Wishlist[]
  settlements  Settlement[]
  payments     Payment[]
  formFields   PartyFormField[]
  chatRoom     ChatRoom?

  @@index([adminId])
  @@index([date])
  @@index([featuredUntil])
  @@index([businessId])
  @@map("parties")
}

model Application {
  id      String            @id @default(cuid())
  status  ApplicationStatus @default(PENDING)
  message String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers ApplicationAnswer[]

  @@unique([userId, partyId])
  @@index([userId])
  @@index([partyId])
  @@map("applications")
}

model UserRating {
  id      String @id @default(cuid())
  score   Int
  comment String

  targetUserId String
  targetUser   User   @relation("TargetRatings", fields: [targetUserId], references: [id], onDelete: Cascade)

  adminId String
  admin   User   @relation("AdminRatings", fields: [adminId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([targetUserId, adminId])
  @@index([targetUserId])
  @@index([adminId])
  @@map("user_ratings")
}

model PartyRating {
  id      String  @id @default(cuid())
  score   Int
  comment String?

  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([partyId, userId])
  @@index([partyId])
  @@index([userId])
  @@map("party_ratings")
}

model NotificationToken {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String
  deviceType DeviceType @default(MOBILE)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([userId, token])
  @@index([userId])
  @@index([token])
  @@map("notification_tokens")
}

model NotificationHistory {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String
  status      NotificationStatus @default(PENDING)
  clickAction String?
  jobId       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId])
  @@index([status])
  @@map("notification_history")
}

model UserNotificationSetting {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  enableMarketing   Boolean   @default(false)
  enableWishlist    Boolean   @default(false)
  enableSeatOpen    Boolean   @default(false)
  enableApplication Boolean   @default(true)
  enableSystem      Boolean   @default(true)
  enableChat        Boolean   @default(true)
  nightAdConsent    Boolean   @default(false)
  nightAdConsentAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_notification_settings")
}

model Wishlist {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, partyId])
  @@index([userId])
  @@index([partyId])
  @@map("wishlist")
}

model DeletedUser {
  id         String   @id @default(cuid())
  originalId String
  email      String
  nickname   String
  reason     String
  deletedAt  DateTime @default(now())

  @@index([originalId])
  @@index([email])
  @@map("deleted_users")
}

/// 회원탈퇴 별도 테이블 (spot-backend 미러링 — 같은 DB). 재가입 차단 + 1년 후 파기.
model WithdrawnUser {
  id                 String   @id @default(cuid())
  originalId         String
  socialId           String
  provider           Provider
  email              String
  nickname           String
  reason             String?
  withdrawnAt        DateTime @default(now())
  rejoinBlockedUntil DateTime
  purgeAt            DateTime

  @@index([socialId, provider])
  @@index([purgeAt])
  @@map("withdrawn_users")
}

// ============================================================
// New Admin Models
// ============================================================

/// 어드민 전용 계정 (이메일/패스워드 인증 — 소셜 로그인과 무관)
model AdminAccount {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(BUSINESS)
  isActive     Boolean   @default(true)

  /// BUSINESS 역할이면 연결된 업체
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([businessId])
  @@map("admin_accounts")
}

/// 업체 (파티를 운영하는 사업자)
model Business {
  id             String         @id @default(cuid())
  name           String
  description    String?
  logoUrl        String?
  contactEmail   String?
  contactPhone   String?
  address        String?
  businessNumber String?
  status         BusinessStatus @default(PENDING)

  /// 플랫폼 중개 수수료율 (basis points, 0~10000). 1000 = 10%.
  /// 파트너/제휴 업체는 낮게(예: 500 = 5%) 설정한다. spot-backend 정산에서 사용.
  feeRateBps Int @default(1000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admins           AdminAccount[]
  parties          Party[]
  settlements      Settlement[]
  invitations      BusinessInvitation[]
  refundPolicyTiers RefundPolicyTier[]
  formFields       BusinessFormField[]
  chatRooms        ChatRoom[]
  adminUsers       User[]               @relation("BusinessAdminUsers")

  @@index([status])
  @@map("businesses")
}

/// 업체별 환불 규정 단계.
/// "파티 시작 hoursBeforeStart 시간 이상 남았을 때 refundPercent% 환불"을 의미한다.
model RefundPolicyTier {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  hoursBeforeStart Int
  refundPercent    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@map("refund_policy_tiers")
}

/// 업체 어드민 초대 링크 (슈퍼 어드민 → 업체 이메일로 발송)
model BusinessInvitation {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  used       Boolean  @default(false)
  expiresAt  DateTime

  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
  @@map("business_invitations")
}

/// Toss Payments 결제 (참가자 → 파티 결제)
model Payment {
  id        String        @id @default(cuid())
  /// Toss Payments 주문 ID (orderId) — 고유해야 함
  orderId   String        @unique
  /// Toss Payments 결제 키 (확정 후 채워짐)
  paymentKey String?      @unique
  status    PaymentStatus @default(READY)
  method    PaymentMethod?
  amount    Int

  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  partyId String
  party   Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  /// 파티 결제 확정 시 자동 생성
  settlementId String?     @unique
  settlement   Settlement? @relation(fields: [settlementId], references: [id])

  /// Toss API 원본 응답 JSON
  tossRawResponse Json?

  /// 유료 파티 커스텀 신청 폼 답변 (spot-backend 미러링)
  formAnswers Json?

  approvedAt  DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  transactions PaymentTransaction[]
  refunds      Refund[]

  @@index([userId])
  @@index([partyId])
  @@index([status])
  @@index([orderId])
  @@map("payments")
}

/// 결제 취소/부분취소 트랜잭션 이력
model PaymentTransaction {
  id        String @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  /// cancel | approve
  type       String
  /// 해당 트랜잭션 금액
  amount     Int
  /// 취소 사유 (cancel 시)
  reason     String?
  /// Toss 트랜잭션 키
  transactionKey String?

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@map("payment_transactions")
}

/// 정산 (Toss Payments 연동 예정)
model Settlement {
  id         String           @id @default(cuid())
  businessId String
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  partyId    String
  party      Party            @relation(fields: [partyId], references: [id], onDelete: Cascade)
  status     SettlementStatus @default(PENDING)

  totalAmount    Int      @default(0)
  feeAmount      Int      @default(0)
  netAmount      Int      @default(0)
  tossPaymentKey String?
  settledAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment Payment?

  @@index([businessId])
  @@index([partyId])
  @@index([status])
  @@map("settlements")
}

/// 환불 요청/이력. 스키마 소스는 spot-backend. (읽기/규정편집용 미러)
model Refund {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  userId     String
  partyId    String
  businessId String?

  amount        Int
  refundPercent Int
  status        RefundStatus @default(REQUESTED)
  reason        String?
  tossTransactionKey String?

  requestedAt DateTime  @default(now())
  decidedAt   DateTime?
  decidedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentId])
  @@index([userId])
  @@index([partyId])
  @@index([businessId])
  @@index([status])
  @@map("refunds")
}

/// 앱 홈 메인 배너 (테이블 소유권은 spot-backend 마이그레이션)
model Banner {
  id        String  @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("banners")
}

// ============================================================
// 업체 커스텀 신청 폼 (spot-backend schema.prisma 미러링 — 같은 DB)
// ============================================================

model BusinessFormField {
  id         String        @id @default(cuid())
  businessId String
  business   Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  label      String
  type       FormFieldType @default(TEXT)
  options    String[]      @default([])
  required   Boolean       @default(false)
  order      Int           @default(0)
  archived   Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partyLinks         PartyFormField[]
  applicationAnswers ApplicationAnswer[]
  userAnswers        UserBusinessFormAnswer[]

  @@index([businessId])
  @@map("business_form_fields")
}

model PartyFormField {
  id       String            @id @default(cuid())
  partyId  String
  party    Party             @relation(fields: [partyId], references: [id], onDelete: Cascade)
  fieldId  String
  field    BusinessFormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  order    Int               @default(0)
  required Boolean?

  @@unique([partyId, fieldId])
  @@index([partyId])
  @@map("party_form_fields")
}

model ApplicationAnswer {
  id            String            @id @default(cuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fieldId       String
  field         BusinessFormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value         String

  createdAt DateTime @default(now())

  @@unique([applicationId, fieldId])
  @@index([applicationId])
  @@map("application_answers")
}

model UserBusinessFormAnswer {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  fieldId    String
  field      BusinessFormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value      String

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, fieldId])
  @@index([userId, businessId])
  @@map("user_business_form_answers")
}

/// 운영 중 변경 가능한 런타임 설정 (spot-backend 미러링 — 같은 DB).
// ============================================================
// Chat (파티 그룹채팅 · 유저 DM · 업체 DM) — spot-backend와 동기화 유지
// ============================================================

model ChatRoom {
  id   String       @id @default(cuid())
  type ChatRoomType

  partyId String? @unique
  party   Party?  @relation(fields: [partyId], references: [id], onDelete: Cascade)

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// DM: "dm:{작은 userId}:{큰 userId}" · BIZ_DM: "biz:{businessId}:{userId}"
  pairKey String? @unique

  lastMessageAt      DateTime?
  lastMessagePreview String?

  /// BIZ_DM 업체 측 읽음 기준 seq — 어드민 수신함 안읽음 배지용
  businessLastReadSeq BigInt @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ChatRoomMember[]
  messages ChatMessage[]

  @@index([type, lastMessageAt])
  @@index([businessId])
  @@map("chat_rooms")
}

model ChatRoomMember {
  id     String   @id @default(cuid())
  roomId String
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadSeq BigInt    @default(0)
  leftAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_room_members")
}

model ChatMessage {
  id  String @id @default(cuid())
  seq BigInt @unique @default(autoincrement())

  roomId String
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  senderType    ChatSenderType @default(USER)
  senderId      String?
  sender        User?          @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderAdminId String?

  content         String
  type            ChatMessageType @default(TEXT)
  mediaUrl        String?
  thumbnailUrl    String?
  mediaWidth      Int?
  mediaHeight     Int?
  clientMessageId String?

  createdAt DateTime @default(now())

  @@unique([roomId, clientMessageId])
  @@index([roomId, seq])
  @@map("chat_messages")
}

/// 유저 채팅방 삭제 스냅샷 보관 — spot-backend 미러
model ChatRoomArchive {
  id                 String       @id @default(cuid())
  archivedByUserId   String
  originalRoomId     String
  roomType           ChatRoomType
  partyId            String?
  businessId         String?
  pairKey            String?
  title              String?
  lastMessageAt      DateTime?
  lastMessagePreview String?
  messagesJson       Json
  archivedAt         DateTime     @default(now())

  @@index([archivedByUserId, archivedAt])
  @@index([originalRoomId])
  @@map("chat_room_archives")
}

model AppSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("app_settings")
}
